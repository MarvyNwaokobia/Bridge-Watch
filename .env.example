# ===========================================
# Stellar Bridge Watch - Environment Variables
# ===========================================

# Application
NODE_ENV=development
PORT=3001

# PostgreSQL + TimescaleDB
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=bridge_watch
POSTGRES_USER=bridge_watch
POSTGRES_PASSWORD=your_password_here

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Stellar Network
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Ethereum RPC (for bridge contract verification)
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

# External APIs
CIRCLE_API_KEY=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# WebSocket
WS_PORT=3002

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Alert Thresholds
PRICE_DEVIATION_THRESHOLD=0.02
BRIDGE_SUPPLY_MISMATCH_THRESHOLD=0.01
